---
// src/components/widgets/FacilityMap.astro
// Single Facility Map Component

export interface Props {
  lat: number;
  lng: number;
  title: string;
  height?: string;
}

const { lat, lng, title, height = '300px' } = Astro.props;
---

<div class="relative w-full rounded-xl overflow-hidden shadow-md border border-slate-200 dark:border-slate-800 my-8">
  <div id="facility-single-map" class="w-full" style={`height: ${height};`} data-lat={lat} data-lng={lng} data-title={title}></div>
  <div class="absolute bottom-4 left-4 z-[400]">
    <a 
      href={`https://www.google.com/maps/search/?api=1&query=${lat},${lng}`} 
      target="_blank" 
      rel="noopener noreferrer"
      class="bg-white/90 dark:bg-slate-800/90 px-3 py-1.5 rounded shadow-sm text-xs font-bold flex items-center gap-1.5 hover:bg-white dark:hover:bg-slate-800 transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11a3 3 0 1 0 6 0a3 3 0 0 0 -6 0" /><path d="M17.657 16.657l-4.242 4.242a2 2 0 0 1 -2.827 0l-4.244 -4.243a8 8 0 1 1 11.314 0z" /></svg>
      Googleマップで開く
    </a>
  </div>
</div>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';

  document.addEventListener('astro:page-load', () => {
    const mapEl = document.getElementById('facility-single-map');
    if (!mapEl) return;

    const lat = parseFloat(mapEl.getAttribute('data-lat') || '0');
    const lng = parseFloat(mapEl.getAttribute('data-lng') || '0');
    const title = mapEl.getAttribute('data-title') || '釣り場';

    if (!lat || !lng) return;

    // Remove existing map if any (important for View Transitions)
    const container = mapEl.parentElement;
    if (container && (mapEl as any)._leaflet_id) {
       // Leaflet doesn't like re-initializing on the same element without cleaning up
       // But with View Transitions, the element might be new anyway.
    }

    const map = L.map('facility-single-map', {
      scrollWheelZoom: false,
    }).setView([lat, lng], 15);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
    }).addTo(map);

    // Marker
    L.marker([lat, lng]).addTo(map).bindPopup(title).openPopup();
    
    // Fix gray boxes
    setTimeout(() => map.invalidateSize(), 500);
  });
</script>
