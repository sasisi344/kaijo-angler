---
// src/components/widgets/FishingHeatmap.astro
import facilitiesGeo from '~/data/facilities-geo.json';

export interface Props {
  id?: string;
  height?: string;
  center?: [number, number];
  zoom?: number;
  title?: string;
  subtitle?: string;
  /**
   * 施設ごとの重み付けデータ (オプション)
   * { "slug": weight } 形式
   */
  weights?: Record<string, number>;
}

const { 
  id = 'fishing-heatmap', 
  height = '600px', 
  center = [35.0, 136.5], // 伊勢湾付近をデフォルト
  zoom = 8,
  title = "海上釣り堀 活性度ヒートマップ",
  subtitle = "最新のリサーチデータに基づいた全国の釣り堀の盛り上がりを可視化"
} = Astro.props;

// データを整形
const points = facilitiesGeo.map(f => ({
  lat: f.latitude,
  lng: f.longitude,
  title: f.title,
  slug: f.slug
}));
---

<section class="relative not-prose scroll-mt-[72px] py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    {title && (
      <div class="max-w-3xl mb-8 md:mx-auto md:mb-12 text-center">
        <h2 class="font-bold leading-tighter tracking-tighter font-heading text-heading text-3xl md:text-4xl mb-4">
          {title}
        </h2>
        {subtitle && (
          <p class="text-muted text-xl dark:text-slate-400">
            {subtitle}
          </p>
        )}
      </div>
    )}

    <div class="relative w-full rounded-2xl overflow-hidden shadow-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 group">
      <div 
        id={id} 
        class="w-full z-10" 
        style={`height: ${height};`} 
        data-points={JSON.stringify(points)}
        data-weights={JSON.stringify(Astro.props.weights || {})}
        data-center={JSON.stringify(center)}
        data-zoom={zoom}
      ></div>
      
      <!-- Overlay controls/info if needed -->
      <div class="absolute top-4 right-4 z-[400] bg-white/90 dark:bg-slate-800/90 p-3 rounded-lg shadow-md border border-slate-200 dark:border-slate-700 backdrop-blur-sm pointer-events-none">
        <div class="flex items-center gap-2 mb-1">
          <div class="w-3 h-3 rounded-full bg-red-500 animate-pulse"></div>
          <span class="text-xs font-bold text-slate-800 dark:text-slate-200">LIVE: 活性度解析中</span>
        </div>
        <p class="text-[10px] text-slate-500 dark:text-slate-400">※過去の釣果・キーワード頻度による相対評価</p>
      </div>

      <!-- Legend -->
      <div class="absolute bottom-6 left-6 z-[400] bg-white/95 dark:bg-slate-800/95 p-3 rounded-xl shadow-lg border border-slate-200 dark:border-slate-700 backdrop-blur-sm hover:opacity-10 transition-opacity">
        <div class="text-[10px] font-bold text-slate-500 dark:text-slate-400 mb-2 uppercase tracking-wider">Activity level</div>
        <div class="h-2 w-32 rounded-full bg-gradient-to-r from-blue-500 via-green-500 via-yellow-500 to-red-600 mb-1"></div>
        <div class="flex justify-between text-[10px] font-bold text-slate-600 dark:text-slate-300">
          <span>SILENT</span>
          <span>ACTIVE</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';
  import 'leaflet.heat';

  const initMap = () => {
    const mapEls = document.querySelectorAll('[id^="fishing-heatmap"]');
    
    mapEls.forEach(mapEl => {
      if (!mapEl) return;
      
      // すでに初期化済みの場合はスキップ
      if ((mapEl as any)._leaflet_id) return;

      const pointsData = JSON.parse(mapEl.getAttribute('data-points') || '[]');
      const weightsData = JSON.parse(mapEl.getAttribute('data-weights') || '{}');
      const center = JSON.parse(mapEl.getAttribute('data-center') || '[35.0, 136.5]');
      const zoom = parseInt(mapEl.getAttribute('data-zoom') || '8');

      const map = L.map(mapEl.id, {
        scrollWheelZoom: false,
      }).setView(center, zoom);

      const isDark = document.documentElement.classList.contains('dark');
      const tileUrl = isDark 
        ? 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png'
        : 'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png';

      L.tileLayer(tileUrl, {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
        subdomains: 'abcd',
        maxZoom: 19
      }).addTo(map);

      // 強度の最大値を算出 (相対評価のため)
      let maxWeight = 0;
      Object.values(weightsData).forEach((v: any) => {
        if (v > maxWeight) maxWeight = v;
      });
      if (maxWeight === 0) maxWeight = 1.0; // フォールバック

      // ヒートマップ用データ作成 [lat, lng, intensity]
      // 重みがない場合はデフォルト値を設定
      const heatPoints = pointsData.map(p => {
        const rawWeight = weightsData[p.slug] || weightsData[p.title] || 0.1;
        // 最大値を1.0として正規化
        const intensity = maxWeight > 0 ? (rawWeight / maxWeight) : 0.1;
        
        // 最低限の活性を表示するために底上げ (0.1〜1.0)
        const adjustedIntensity = Math.max(0.1, intensity);
        
        return [p.lat, p.lng, adjustedIntensity];
      });

      // @ts-ignore
      L.heatLayer(heatPoints, {
        radius: 35, // 少し広めに
        blur: 20,
        maxZoom: 17,
        max: 1.0,
        gradient: {
          0.1: 'blue', 
          0.3: 'cyan', 
          0.5: 'lime', 
          0.7: 'yellow', 
          1.0: 'red'
        }
      }).addTo(map);

      pointsData.forEach(p => {
        const circleMarker = L.circleMarker([p.lat, p.lng], {
          radius: 3,
          fillColor: "#ffffff",
          color: "#000",
          weight: 1,
          opacity: 0.3,
          fillOpacity: 0.2
        }).addTo(map);
        
        circleMarker.bindPopup(`<strong>${p.title}</strong><br><a href="/blog/${p.slug}" class="text-blue-500 underline">施設詳細</a>`);
      });

      setTimeout(() => map.invalidateSize(), 500);
    });
  };

  document.addEventListener('astro:page-load', initMap);
</script>
