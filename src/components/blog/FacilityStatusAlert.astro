---
import { Icon } from 'astro-icon/components';

export interface Props {
  status?: 'closed' | 'suspended';
}

const { status } = Astro.props;

if (!status) return null;

const config = {
  closed: {
    icon: 'tabler:alert-triangle',
    title: 'この施設は閉鎖・廃止されました',
    description: '掲載されている情報は当時のものであり、現在は営業しておりません。周辺の他施設をお探しください。',
    colorClass: 'bg-red-50 border-red-200 text-red-800 dark:bg-red-900/20 dark:border-red-900/30 dark:text-red-400',
    iconColor: 'text-red-500',
  },
  suspended: {
    icon: 'tabler:info-circle',
    title: 'この施設は現在休止中です',
    description: '一時的に営業を休止している、あるいは再開待ちの状態です。最新の状況は公式サイト等でご確認ください。',
    colorClass: 'bg-amber-50 border-amber-200 text-amber-800 dark:bg-amber-900/20 dark:border-amber-900/30 dark:text-amber-400',
    iconColor: 'text-amber-500',
  },
};

const current = config[status];
---

<div class={`flex p-4 mb-8 border rounded-lg ${current.colorClass}`} role="alert" data-status={status}>
  <Icon name={current.icon} class={`w-6 h-6 mr-3 flex-shrink-0 ${current.iconColor}`} />
  <div>
    <h3 class="text-lg font-bold leading-none mb-1">{current.title}</h3>
    <p class="text-sm opacity-90">{current.description}</p>
  </div>
</div>
