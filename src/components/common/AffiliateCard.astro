---
import { getEntry } from "astro:content";
import type { CollectionEntry } from "astro:content";

interface Props {
  product?: CollectionEntry<"affiliates">["data"];
  id?: string;
  isVertical?: boolean;
}

const { product: initialProduct, id, isVertical = false } = Astro.props;

let product = initialProduct;

if (id && !product) {
  const entry = await getEntry("affiliates", id);
  if (entry) {
    product = entry.data;
  }
}

// Logic for lazy data extraction from SiteStripe HTML
let finalLink = "";
let finalImage = "";
let amazonSearch = "";
let rakutenSearch = "";
let yahooSearch = "";
let isService = false;

if (product) {
  finalLink = product.link || "";
  finalImage = product.image || "";

  if (product.html) {
    // Extract link
    const linkMatch = product.html.match(/href="([^"]+)"/);
    if (linkMatch) finalLink = linkMatch[1];

    // Extract all images and find the one that isn't a tracking pixel (1x1)
    const srcMatches = [...product.html.matchAll(/src="([^"]+)"/g)];
    const productImages = srcMatches
      .map(m => m[1])
      .filter(src => !src.includes('/ir?') && !src.includes('1x1'));
      
    if (productImages.length > 0) {
      finalImage = productImages[0];
      if (finalImage.startsWith('//')) finalImage = 'https:' + finalImage;
    }
  }

  // Affiliate Identifiers (Hardcoded for reliability or can be moved to config)
  const AMAZON_TAG = 'sasisi344-22';
  const VC_YAHOO_SID = '3758616';
  const VC_RAKUTEN_SID = '3748070';
  const VC_YAHOO_PID = '892569590';
  const VC_RAKUTEN_PID = '892569778';

  // Optimize Amazon image URLs
  if (finalImage && finalImage.includes('media-amazon.com/images/P/')) {
    finalImage = finalImage.replace(/\.01\.LZZZZZZZ\./, '.01._AC_SY320_.');
  } else if (finalImage && finalImage.includes('media-amazon.com/images/I/')) {
    finalImage = finalImage.replace(/\.jpg$/, '._AC_SY320_.jpg');
  }

  // Generate Search Buttons for Tackle/Goods
  const query = product.search_query || product.name;
  const encodedName = encodeURIComponent(query);
  amazonSearch = `https://www.amazon.co.jp/s?k=${encodedName}&tag=${AMAZON_TAG}`;
  rakutenSearch = `https://ck.jp.ap.valuecommerce.com/servlet/referral?sid=${VC_RAKUTEN_SID}&pid=${VC_RAKUTEN_PID}&vc_url=https%3A%2F%2Fsearch.rakuten.co.jp%2Fsearch%2Fmall%2F${encodedName}`;
  yahooSearch = `https://ck.jp.ap.valuecommerce.com/servlet/referral?sid=${VC_YAHOO_SID}&pid=${VC_YAHOO_PID}&vc_url=https%3A%2F%2Fshopping.yahoo.co.jp%2Fsearch%3Fp%3D${encodedName}`;

  isService = product.id.startsWith('travel/');
}
---

{!product ? (
  <div class="my-8 p-4 border border-red-500/30 bg-red-500/10 rounded-xl text-red-500 text-sm font-semibold">
    ⚠️ アフィリエイトID "{id}" が見つかりませんでした。
  </div>
) : (
  <div class:list={["not-prose group relative flex gap-6 p-6 rounded-2xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 hover:border-blue-400 dark:hover:border-blue-500 transition-all duration-300 shadow-sm hover:shadow-xl overflow-hidden my-8", isVertical ? "flex-col" : "flex-col sm:flex-row"]}>
    <div class:list={["shrink-0 w-full h-48 rounded-xl overflow-hidden bg-white dark:bg-slate-800 border border-slate-100 dark:border-slate-700 flex items-center justify-center p-2", isVertical ? "" : "sm:w-48"]}>
      {finalImage ? (
        <img 
          src={finalImage} 
          alt={product.name} 
          width="320"
          height="320"
          loading="lazy"
          class="max-w-full max-h-full object-contain group-hover:scale-105 transition-transform duration-500"
        />
      ) : (
        <div class="flex items-center justify-center w-full h-full bg-slate-100 dark:bg-slate-800 text-slate-400">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect>
            <circle cx="9" cy="9" r="2"></circle>
            <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
          </svg>
        </div>
      )}
    </div>

    <div class="flex-1 flex flex-col space-y-3">
      <div class="flex items-center gap-2">
        {product.brand && (
          <span class="text-[10px] font-bold uppercase tracking-wider text-slate-500 bg-slate-100 dark:bg-slate-800 px-2 py-0.5 rounded border border-slate-200 dark:border-slate-700">
            {product.brand}
          </span>
        )}
        {product.isRecommended && (
          <span class="text-[10px] font-bold uppercase tracking-wider text-amber-600 bg-amber-50 dark:bg-amber-900/30 px-2 py-0.5 rounded border border-amber-200 dark:border-amber-800 flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="currentColor" stroke="none">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg>
            おすすめ
          </span>
        )}
      </div>

      <h3 class="text-xl font-bold text-slate-900 dark:text-white leading-tight">
        {product.name}
      </h3>

      {product.description && (
        <p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-2">
          {product.description}
        </p>
      )}

      <div class="flex flex-wrap gap-2 text-[11px]">
        {product.categories.map(cat => (
          <span class="px-2 py-0.5 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 rounded-md border border-slate-200 dark:border-slate-700">
            {cat}
          </span>
        ))}
        {!isService && product.targetFish.map(fish => (
          <span class="px-2 py-0.5 bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 rounded-md border border-blue-100 dark:border-blue-900/30">
            🐟 {fish}
          </span>
        ))}
      </div>

      <div class="mt-auto pt-4 flex flex-col gap-3">
        {isService ? (
          <a 
            href={finalLink} 
            target="_blank" 
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg transition-colors text-sm shadow-md hover:shadow-lg active:translate-y-0.5 no-underline"
          >
            公式サイトで詳細を見る
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
              <polyline points="15 3 21 3 21 9"></polyline>
              <line x1="10" y1="14" x2="21" y2="3"></line>
            </svg>
          </a>
        ) : (
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
            <a 
              href={finalLink || amazonSearch} 
              target="_blank" 
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center px-4 py-2 bg-neutral-800 dark:bg-black hover:bg-neutral-900 text-white font-bold rounded text-xs transition-colors no-underline"
            >
              Amazon
            </a>
            <a 
              href={product.rakuten_link || rakutenSearch} 
              target="_blank" 
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center px-4 py-2 bg-[#bf0000] hover:bg-[#a00000] text-white font-bold rounded text-xs transition-colors no-underline"
            >
              楽天
            </a>
            <a 
              href={product.yahoo_link || yahooSearch} 
              target="_blank" 
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center px-4 py-2 bg-[#ff0033] hover:bg-[#e6002e] text-white font-bold rounded text-xs transition-colors no-underline"
            >
              Yahoo!
            </a>
          </div>
        )}
      </div>
    </div>
  </div>
)}
