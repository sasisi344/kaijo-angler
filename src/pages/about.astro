---
import Features2 from "~/components/widgets/Features2.astro";
import Features3 from "~/components/widgets/Features3.astro";
import Hero from "~/components/widgets/Hero.astro";
import Stats from "~/components/widgets/Stats.astro";
import Steps2 from "~/components/widgets/Steps2.astro";
import Layout from "~/layouts/PageLayout.astro";
import heroImage from "~/assets/images/about/hero.png";

const metadata = {
  title: "海上アングラーについて",
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="About Kaijo Angler"
    image={{
      src: heroImage,
      alt: "海上釣り堀の風景",
    }}
  >
    <Fragment slot="title">
      海上釣り堀の感動を、<br />
      <span class="text-accent dark:text-white">すべてのアングラーへ。</span>
    </Fragment>

    <Fragment slot="subtitle">
      「海上アングラー」は、全国<strong>100施設以上</strong>・<strong
        >50エリア以上</strong
      >の海上釣り堀情報と<strong>90本以上</strong
      >の攻略記事を擁する、日本最大級の海上釣り堀特化型メディアです。
      初心者から上級者まで、あなたの釣果と体験を最高のものにする情報をお届けします。
    </Fragment>
  </Hero>

  <!-- Stats Widget ****************** -->

  <Stats
    title="数字で見る海上アングラー"
    stats={[
      { title: "掲載施設数", amount: "100+" },
      { title: "検索エリア", amount: "50+" },
      { title: "必釣タクティクス", amount: "90+" },
      { title: "情報量国内", amount: "1位" },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="提供するコンテンツ"
    subtitle="私たちは「情報の正確性」と「アングラー目線」を大切にしています。"
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: "全国100施設以上のガイド",
        description:
          "北海道から沖縄まで50エリア以上をカバー。料金・営業時間・放流魚種・設備情報を現地調査データで提供します。",
        icon: "tabler:map-pin",
      },
      {
        title: "12魚種対応の攻略テクニック",
        description:
          "真鯛・ブリ・シマアジ・クエなど全12魚種に対応。90本以上の記事でターゲットごとの「棚・餌・合わせ」を徹底解説。",
        icon: "tabler:target",
      },
      {
        title: "最新タックル紹介",
        description:
          "初心者におすすめのセットから、玄人も納得の特化竿まで。失敗しない道具選びを豊富な記事でサポート。",
        icon: "tabler:fish",
      },
    ]}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="私たちのミッション"
    subtitle="釣りの楽しさを伝え、豊かな海と家族の絆を育む。"
    items={[
      {
        title: "「手ぶら」から始まる感動を",
        description:
          "釣りは道具が多くて難しい。そんな先入観を払い、誰もが手軽に海の恵みを楽しめる環境を作ります。",
      },
      {
        title: "持続可能な釣り文化の醸成",
        description:
          "マナーやルールを守り、次世代のアングラーに美しい海と豊かな魚影を残すための啓蒙活動を行います。",
      },
      {
        title: "「食」を通じた体験価値の向上",
        description:
          "自分で釣った魚を美味しく食べる。その究極の食育体験こそが、海上釣り堀の真の魅力だと信じています。",
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="運営・プロフィール"
    tagline="About Admin"
    columns={2}
    items={[
      {
        title: "さしし (運営・執筆)",
        description:
          "海釣り経験20年以上のアングラーライター。海上釣り堀を「次世代の持続可能なフィッシングスタイル」と捉え、自身の100回を超える釣行経験から、初心者の方でも最高の一日を過ごせるよう役立つ情報を発信しています。",
        icon: "tabler:user",
        callToAction: {
          text: "公式X (旧Twitter)",
          href: "https://x.com/sasisi344",
          target: "_blank",
        },
      },
      {
        title: "お問い合わせ",
        description:
          "取材・撮影依頼、広告掲載、記事内容に関するご相談は、下記Googleフォームよりお気軽にご連絡ください。<br />順次、運営より回答させていただきます。",
        icon: "tabler:mail",
        callToAction: {
          text: "お問い合わせフォーム",
          href: "https://docs.google.com/forms/d/e/1FAIpQLSegPHwMqUtKjHl0y1OTPrNr0aaW7Hmt7jluuZ9FUQYdv362Dg/viewform?usp=sf_link",
          target: "_blank",
        },
      },
    ]}
  />
</Layout>
