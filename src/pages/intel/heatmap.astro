---
import Layout from '~/layouts/PageLayout.astro';
import FishingHeatmap from '~/components/widgets/FishingHeatmap.astro';

const metadata = {
  title: '海上釣り堀 活性度インテリジェンスヒートマップ',
  description: '全国の海上釣り堀の最新活性度を可視化したヒートマップです。',
};
---

<Layout metadata={metadata}>
  <div class="py-12 bg-slate-50 dark:bg-slate-900/50 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      
      <!-- Breadcrumbs -->
      <nav class="flex mb-8 text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-widest" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
          <li class="inline-flex items-center">
            <a href="/" class="hover:text-primary transition-colors">Home</a>
          </li>
          <li>
            <div class="flex items-center">
              <span class="mx-2">/</span>
              <span class="text-slate-400">Intelligence</span>
            </div>
          </li>
          <li>
            <div class="flex items-center border-b border-primary/50">
              <span class="mx-2">/</span>
              <span class="text-primary font-bold">Heatmap</span>
            </div>
          </li>
        </ol>
      </nav>

      <div class="flex flex-col lg:flex-row gap-8 items-end mb-12">
        <div class="flex-1">
          <div class="inline-flex items-center bg-blue-100 dark:bg-blue-900/50 text-blue-800 dark:text-blue-300 px-3 py-1 rounded-full text-xs font-bold mb-4 border border-blue-200 dark:border-blue-800 tracking-wider uppercase">
            Alpha Release
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black mb-6 leading-tight text-heading">
            Fishing Heatmap <br/><span class="text-primary italic">Intelligence</span>
          </h1>
          <p class="text-xl text-muted dark:text-slate-400 max-w-2xl leading-relaxed">
            全国の施設データを統合し、AIが最新の釣果トレンドを解析。今、最も「アツい」海上釣り堀はどこか。一目で把握するための戦略的データ視覚化。
          </p>
        </div>
        
        <div class="flex flex-wrap gap-4 bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-xl border border-slate-200 dark:border-slate-700 min-w-[280px]">
          <div class="flex flex-col border-r border-slate-200 dark:border-slate-700 pr-6 mr-6">
            <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Last Update</span>
            <span class="text-lg font-black text-slate-800 dark:text-white">2026.04.01</span>
          </div>
          <div class="flex flex-col border-r border-slate-200 dark:border-slate-700 pr-6 mr-6">
            <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Facilities</span>
            <span class="text-lg font-black text-slate-800 dark:text-white">113 Spots</span>
          </div>
          <div class="flex flex-col">
            <span class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1">Status</span>
            <span class="text-lg font-black text-green-500 flex items-center gap-1.5">
              <div class="w-2 h-2 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.6)]"></div>
              Active
            </span>
          </div>
        </div>
      </div>

      <!-- Main Visual Section -->
      <div class="bg-gradient-to-b from-transparent to-slate-100 dark:to-slate-950 p-1 md:p-4 rounded-3xl mb-24">
        <FishingHeatmap 
          title="" 
          subtitle="" 
          height="700px" 
          center={[34.8, 137.5]} 
          zoom={7}
        />
      </div>

      <!-- Features / Info section -->
      <div class="grid md:grid-cols-3 gap-8 mb-24">
        <div class="bg-white dark:bg-slate-800 p-8 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 hover:shadow-xl transition-all hover:-translate-y-1">
          <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-xl flex items-center justify-center text-primary mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M2 12h20"/><path d="m4.93 4.93 14.14 14.14M4.93 19.07 19.07 4.93"/></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">高精度な位置情報</h3>
          <p class="text-muted dark:text-slate-400 text-sm leading-relaxed">
            各施設の正確な緯度経度データを使用。港の正確な位置をマークし、地域ごとの密集度をヒートマップで正確に再現します。
          </p>
        </div>
        
        <div class="bg-white dark:bg-slate-800 p-8 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 hover:shadow-xl transition-all hover:-translate-y-1">
          <div class="w-12 h-12 bg-red-100 dark:bg-red-900/30 rounded-xl flex items-center justify-center text-red-500 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/><path d="M12 7v5l3 3"/></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">リアルタイム性（予定）</h3>
          <p class="text-muted dark:text-slate-400 text-sm leading-relaxed">
            今後、各施設の最新釣果情報をスクレイピングし、AIが「今週釣れている場所」をウェイト付けして動的にマップを更新します。
          </p>
        </div>

        <div class="bg-white dark:bg-slate-800 p-8 rounded-2xl shadow-sm border border-slate-100 dark:border-slate-700 hover:shadow-xl transition-all hover:-translate-y-1">
          <div class="w-12 h-12 bg-green-100 dark:bg-green-900/30 rounded-xl flex items-center justify-center text-green-500 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <h3 class="text-xl font-bold mb-3">直感的な地域比較</h3>
          <p class="text-muted dark:text-slate-400 text-sm leading-relaxed">
            三重・和歌山・福井など、主要な釣り堀密集地帯の様子を一望。遠征先の選定に強力なインサイトを提供します。
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .text-heading {
    @apply text-slate-900 dark:text-slate-100;
  }
</style>
